# ==============================
# Puduhue App Web — .gitignore
# ==============================

# === Entorno y credenciales ===
.env
.env.local
.env.*.local
cfg.php

# === Composer (vendor se sube al hosting, no debería versionarse) ===
/vendor/
composer.lock

# === Archivos temporales ===
tmp_*
*.tmp
*.bak
*.swp
*.swo
*~

# === Archivos de respaldo ===
*_bak_*.php
*_backup_*.php
* copy.php
* copy *
*.orig

# === Archivos del cliente/trabajo en raíz (mover a docs/client/) ===
# Descomentar si se mueven manualmente:
# *.xlsx
# *.jpeg
# *.png (solo los sueltos en raíz, no los de assets/)

# === IDE / Editor ===
.vscode/
.idea/
*.code-workspace
.project
.settings/
.buildpath
nbproject/

# === Sistema operativo ===
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# === Logs y archivos de storage (generados en runtime) ===
storage/LOGS/*.log
storage/APILog/*.log
storage/temp/*
!storage/LOGS/.gitkeep
!storage/APILog/.gitkeep
!storage/temp/.gitkeep

# === Uploads de usuario ===
apps/web-php/uploads/**/*
!apps/web-php/uploads/.gitkeep
!apps/web-php/uploads/retiroleche/.gitkeep
!apps/web-php/uploads/retiroleche/img/.gitkeep

# === Node / Tailwind (si se adopta en el futuro) ===
node_modules/
package-lock.json
dist/

# === Caché PHP ===
*.cache
